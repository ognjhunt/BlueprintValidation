{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blueprintvalidation.local/schemas/standardized_eval_report.schema.json",
  "title": "Standardized Evaluation Report",
  "type": "object",
  "required": ["schema_version", "comparisons"],
  "properties": {
    "schema_version": { "const": "v1" },
    "generated_at": { "type": ["string", "null"] },
    "project_name": { "type": ["string", "null"] },
    "comparisons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "comparison_id",
          "facility_id",
          "stage_name",
          "status",
          "runtime_backend_public",
          "metrics",
          "failure_taxonomy"
        ],
        "properties": {
          "comparison_id": { "type": "string" },
          "facility_id": { "type": "string" },
          "stage_name": { "type": "string" },
          "status": { "type": "string" },
          "runtime_backend_internal": { "type": "string" },
          "runtime_backend_public": { "type": "string" },
          "report_path": { "type": "string" },
          "metrics": {
            "type": "object",
            "properties": {
              "mean_task_score_a": {},
              "mean_task_score_b": {},
              "win_rate": {},
              "p_value": {},
              "task_success_proxy": {}
            }
          },
          "failure_taxonomy": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "failure_taxonomy_reference": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
