# Copy to an untracked file (for example `scripts/runtime_env.local`) and source it:
#   set -a && source scripts/runtime_env.local && set +a
#
# Never commit secrets.

export GOOGLE_GENAI_API_KEY="YOUR_GEMINI_KEY"
export HF_TOKEN="hf_..."
export BLUEPRINT_GPU_HOURLY_RATE_USD="3.26"
export BLUEPRINT_AUTO_SHUTDOWN_CMD="sudo poweroff"
export B2_BUCKET="blueprint-validation-checkpoints"
export B2_APPLICATION_KEY_ID="0000000000000000000000003"
export B2_APPLICATION_KEY="K000..."
export ENABLE_B2_SYNC="true"
export RCLONE_OPERATION="sync"  # set to "copy" if your B2 key cannot delete files

# NeoVerse hosted-session runtime bootstrap
# These are expected to be written/populated by first-boot provisioning.
# export NEOVERSE_REPO_URL="https://github.com/IamCreateAI/NeoVerse.git"
# export NEOVERSE_REPO_REF="886772226c909801fb00b9148d9f7fdd4f34e579"
# export NEOVERSE_REPO_PATH="/app/data/vendor/neoverse"
# export NEOVERSE_PYTHON_EXECUTABLE="/app/.venv/bin/python"
# export NEOVERSE_CHECKPOINT_PATH="/models/checkpoints/neoverse/"

# Optional Isaac teleop runtime hints (remote GPU box)
# export ISAACLAB_PYTHON="/path/to/isaac-sim/python.sh"
# export ISAAC_SIM_ROOT="/path/to/isaac-sim"
# export REMOTE_TARGET="user@remote-gpu-host"
# export REMOTE_ROOT="/path/to/BlueprintValidation"
# export TELEOP_DEVICE="vision_pro"
# export BRIDGE_HOST="0.0.0.0"
# export BRIDGE_PORT="49110"
# export PACKET_LOG_PATH="/path/to/vision_pro_relay_packets.jsonl"
