+private func extractEulerRPY(from transform: simd_float4x4) -> SIMD3<Float> {
+    let m = transform
+    let pitch = asin(-m.columns.2.x)
+    let roll = atan2(m.columns.2.y, m.columns.2.z)
+    let yaw = atan2(m.columns.1.x, m.columns.0.x)
+    return SIMD3<Float>(roll, pitch, yaw)
+}

